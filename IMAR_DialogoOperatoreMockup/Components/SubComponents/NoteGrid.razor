@using IMAR_DialogoOperatore.Interfaces.ViewModels
@using IMAR_DialogoOperatore.ViewModels

@inject NoteGridViewModel NoteGridViewModel
@inject IJSRuntime JS

<DxGrid @bind-Data="@NoteGridViewModel.Note"
		AllowSort="false"
		AllowSelectRowByClick="true"
		SelectionMode="GridSelectionMode.Single"
        PageSize="25"
        EditModelSaving="Grid_EditModelSaving"
        CustomizeEditModel="Grid_CustomizeEditModel"
        @ref="Grid"
        id="grid-id">
    <ToolbarTemplate>
        <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Plain">
            <DxToolbarItem Text="Aggiungi"
                           Click="NewItem_Click"
                           RenderStyle="ButtonRenderStyle.Warning"
                           RenderStyleMode="ToolbarItemRenderStyleMode.Plain"
                           CssClass="d-flex justify-content-center align-items-center testo-piccolo p-3" />
        </DxToolbar>
    </ToolbarTemplate>

    <Columns>
        <DxGridDataColumn FieldName="DataImmissione" Width="15%" />
        <DxGridDataColumn FieldName="Operatore" Caption="Badge" Width="10%" />
        <DxGridDataColumn FieldName="Odp" Width="15%" />
        <DxGridDataColumn FieldName="Fase" Width="5%" />
        <DxGridDataColumn FieldName="Bolla" Caption="Codice AI" Width="10%" />
        <DxGridDataColumn FieldName="Testo" />
	</Columns>

    <EditFormTemplate Context="EditFormContext">
        @{
            var nota = (INotaViewModel)EditFormContext.EditModel;
        }
        <DxFormLayout CssClass="w-100">
            <DxFormLayoutItem Caption="Testo:" ColSpanMd="12">
                <div class="d-flex align-items-start gap-2">
                    <DxMemo @bind-Text="@nota.Testo"
                            Rows="3"
                            CssClass="flex-grow-1" />
                    <DxButton Text="@(_isRecording ? "Stop" : "Registra")"
                              RenderStyle="@(_isRecording ? ButtonRenderStyle.Danger : ButtonRenderStyle.Info)"
                              Click="@(() => ToggleRecording(nota))"
                              CssClass="testo-piccolo" />
                </div>
            </DxFormLayoutItem>
        </DxFormLayout>
    </EditFormTemplate>
</DxGrid>

@implements IAsyncDisposable

@code {
    IGrid Grid { get; set; }
    bool EditItemsEnabled { get; set; }

    private DotNetObjectReference<NoteGrid>? _speechDotNetRef;
    private bool _isRecording;
    private INotaViewModel? _currentEditModel;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        NoteGridViewModel.NotifyStateChanged += NoteGridViewModel_NotifyStateChanged;
        _speechDotNetRef = DotNetObjectReference.Create(this);
    }

    protected override Task OnParametersSetAsync()
    {
        StateHasChanged();
        return base.OnParametersSetAsync();
    }

    async void NoteGridViewModel_NotifyStateChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    async Task NewItem_Click()
    {
        await Grid.StartEditNewRowAsync();
    }

    void Grid_CustomizeEditModel(GridCustomizeEditModelEventArgs e)
    {
        if (e.IsNew)
        {
            if (e.EditModel == null)
                e.EditModel = new NotaViewModel(null);
            INotaViewModel nuovaNota = (INotaViewModel)e.EditModel;
            nuovaNota.Testo = "";
        }
    }

    async Task Grid_EditModelSaving(GridEditModelSavingEventArgs e)
    {
        // Ferma eventuale registrazione in corso prima di salvare
        if (_isRecording)
            await StopRecording();

        if (e.IsNew)
        {
            NoteGridViewModel.InsertNuovaNota((INotaViewModel)e.EditModel);
            UpdateEditItemsEnabled(true);
        }
        await LoadGridDataAsync();
    }

    void UpdateEditItemsEnabled(bool enabled)
    {
        EditItemsEnabled = enabled;
    }

    async Task LoadGridDataAsync()
    {
        NoteGridViewModel.Note = NoteGridViewModel.GetNoteAttivita();
    }

    // --- Speech-to-Text ---

    private async Task ToggleRecording(INotaViewModel nota)
    {
        if (_isRecording)
        {
            await StopRecording();
        }
        else
        {
            _currentEditModel = nota;
            _isRecording = true;
            await JS.InvokeVoidAsync("startSpeechRecognition", _speechDotNetRef);
        }
    }

    private async Task StopRecording()
    {
        _isRecording = false;
        _currentEditModel = null;
        await JS.InvokeVoidAsync("stopSpeechRecognition");
    }

    [JSInvokable]
    public async Task OnSpeechResult(string text)
    {
        if (_currentEditModel == null)
            return;

        _currentEditModel.Testo = string.IsNullOrEmpty(_currentEditModel.Testo)
            ? text
            : _currentEditModel.Testo + " " + text;

        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnSpeechEnded()
    {
        _isRecording = false;
        _currentEditModel = null;
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnSpeechError(string error)
    {
        _isRecording = false;
        _currentEditModel = null;
        await InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        if (_isRecording)
            await StopRecording();

        _speechDotNetRef?.Dispose();
    }
}
