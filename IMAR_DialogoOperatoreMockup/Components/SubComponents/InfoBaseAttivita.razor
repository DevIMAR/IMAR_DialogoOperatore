@using DevExpress.Blazor.Internal
@using IMAR_DialogoOperatore.Application
@using IMAR_DialogoOperatore.Interfaces.Observers
@using IMAR_DialogoOperatore.Interfaces.Services
@using IMAR_DialogoOperatore.ViewModels

@inject InfoBaseAttivitaViewModel InfoBaseAttivitaViewModel
@inject IDialogoOperatoreObserver DialogoOperatoreObserver
@inject IDeepLinkParameters DeepLinkParameters
@inject IJSRuntime JS
@inject ILogger<InfoBaseAttivita> Logger

<DxGridLayout>
	<Rows>
		<DxGridLayoutRow Height="auto"/>
		<DxGridLayoutRow Height="auto"/>
		<DxGridLayoutRow Height="auto" />
		<DxGridLayoutRow Height="auto" />
		<DxGridLayoutRow Height="auto" Visible="@ShowArticolo" />
		<DxGridLayoutRow Height="auto" Visible="@ShowArticolo" />
		<DxGridLayoutRow Height="auto" Visible="@ShowDataSchedulata"/>
		<DxGridLayoutRow Height="auto" Visible="@ShowDataSchedulata" />
	</Rows>

	<Columns>
		<DxGridLayoutColumn />
		<DxGridLayoutColumn />
	</Columns>

	<Items>
		<DxGridLayoutItem Row="0" Column="0">
			<Template>
				<div class="d-flex justify-content-center align-items-center h-100 testo-piccolo mt-2">
					<label>BOLLA</label>
				</div>
			</Template>
		</DxGridLayoutItem>

		<DxGridLayoutItem Row="0" Column="1">
			<Template>
				<div class="d-flex justify-content-center align-items-center h-100 testo-piccolo mt-2">
					<label>ODP</label>
				</div>
			</Template>
		</DxGridLayoutItem>

		<DxGridLayoutItem Row="1" Column="0">
			<Template>
				<DxMaskedInput @bind-Value="@(InfoBaseAttivitaViewModel.Bolla)"
							   BindValueMode="BindValueMode.OnInput"
							   Mask="000000"
							   MaskMode="MaskMode.Numeric"
							   CssClass="dxbl-text-edit mt-2 bolla-input"
							   @ref="@BollaRef"
							   inputmode="text"
							   enterkeyhint="enter"
							   Enabled="@(!InfoBaseAttivitaViewModel.IsIndirettaSelezionata && !IsOperazioneDiFine)">
						<Buttons>
							<DxEditorButton Text="Ind"
											Tooltip="Apri indiretta"
											Visible="@ShowBottoneIndirette"
											Click="InfoBaseAttivitaViewModel.ApriListaIndirette.Execute"
											Enabled="InfoBaseAttivitaViewModel.ApriListaIndirette.CanExecute(null)" />
						</Buttons>
				</DxMaskedInput>
			</Template>
		</DxGridLayoutItem>

		<DxGridLayoutItem Row="1" Column="1">
			<Template>
				<DxMaskedInput @bind-Value="@(InfoBaseAttivitaViewModel.Odp)"
							   BindValueMode="BindValueMode.OnInput"
							   Mask="00000000"
							   MaskMode="MaskMode.Numeric"
							   CssClass="dxbl-text-edit mt-2 odp-input"
							   @ref="@OdpRef"
							   inputmode="text"
							   enterkeyhint="enter"
							   Enabled="@(!InfoBaseAttivitaViewModel.IsIndirettaSelezionata && !IsOperazioneDiFine)">
				</DxMaskedInput>
			</Template>
		</DxGridLayoutItem>

		<DxGridLayoutItem Row="2"
						  Column="0" ColumnSpan="2">
			<Template>
				<div class="d-flex justify-content-center align-items-center h-100 testo-piccolo mt-2">
					<label>FASE</label>
				</div>
			</Template>
		</DxGridLayoutItem>

		<DxGridLayoutItem Row="3"
						  Column="0" ColumnSpan="2">
			<Template>
				<DxComboBox Data="@InfoBaseAttivitaViewModel.FasiPerAttivita"
							@bind-Value="@(InfoBaseAttivitaViewModel.FaseSelezionata)"
							Enabled="@(InfoBaseAttivitaViewModel.FasiPerAttivita != null && InfoBaseAttivitaViewModel.FasiPerAttivita.Count() != 0 && !IsOperazioneDiFine)"
							CssClass="dxbl-text-edit mt-2"
							@ref="@FasiRef"
							@onkeydown="HandleFaseKeyPress" />
			</Template>
		</DxGridLayoutItem>

		@if (ShowDescrizioni)
		{
			<DxGridLayoutItem Row="4"
							  Column="0" ColumnSpan="2">
				<Template>
					<div class="d-flex justify-content-center align-items-center h-100 testo-piccolo mt-2">
						<label>ARTICOLO</label>
					</div>
				</Template>
			</DxGridLayoutItem>

			<DxGridLayoutItem Row="5"
							  Column="0" ColumnSpan="2">
				<Template>
					<DxTextBox Text="@(InfoBaseAttivitaViewModel.CodiceDescrizioneArticolo)"
							   Enabled="false"
							   CssClass="dxbl-text-edit mt-2" />
				</Template>
			</DxGridLayoutItem>
		}

		@if (ShowDataSchedulata)
		{
			<DxGridLayoutItem Row="6"
							  Column="0">
				<Template>
					<div class="d-flex justify-content-center align-items-center h-100 testo-piccolo mt-2">
						<label>DATA SCHEDULATA</label>
					</div>
				</Template>
			</DxGridLayoutItem>

			<DxGridLayoutItem Row="7"
							  Column="0">
				<Template>
					<DxTextBox Text="@(InfoBaseAttivitaViewModel.DataSchedulata)"
							   Enabled="false"
							   CssClass="dxbl-text-edit mt-2" />
				</Template>
			</DxGridLayoutItem>

			<DxGridLayoutItem Row="6" RowSpan="2"
							  Column="1"
							  Visible="@(InfoBaseAttivitaViewModel.IsDataSchedulataLontana)">
				<Template>
					<div class="d-flex justify-content-center align-items-center h-100 testo-piccolo ms-2 mt-2 rosso">
						@InfoBaseAttivitaViewModel.TestoDataLontana
					</div>
				</Template>
			</DxGridLayoutItem>

			<DxGridLayoutItem Row="6" RowSpan="2"
							  Column="1"
							  Visible="@(InfoBaseAttivitaViewModel.IsAttivitaSaldata)">
				<Template>
					<div class="d-flex justify-content-center align-items-center h-100 testo-piccolo ms-2 mt-2 rosso">
						@InfoBaseAttivitaViewModel.TestoAttivitaSaldata
					</div>
				</Template>
			</DxGridLayoutItem>

			<DxGridLayoutItem Row="6" RowSpan="2"
							  Column="1"
							  Visible="@(InfoBaseAttivitaViewModel.IsAttivitaNonSchedulata)">
				<Template>
					<div class="d-flex justify-content-center align-items-center h-100 testo-piccolo ms-2 mt-2 giallo">
						@InfoBaseAttivitaViewModel.TestoAttivitaNonSchedulata
					</div>
				</Template>
			</DxGridLayoutItem>
		}
	</Items>
</DxGridLayout>

@implements IAsyncDisposable

@code {
	[Parameter] public EventCallback InfoBaseInserite { get; set; }
	[Parameter] public bool ShowArticolo { get; set; } = false;
	[Parameter] public bool ShowDescrizioni { get; set; } = false;
	[Parameter] public bool ShowDataSchedulata { get; set; } = false;
	[Parameter] public bool ShowBottoneIndirette { get; set; } = false;

	// In Fine Lavoro/Fine Attrezzaggio i campi Bolla, ODP e Fase devono essere readonly
	private bool IsOperazioneDiFine =>
		DialogoOperatoreObserver.OperazioneInCorso == Costanti.FINE_LAVORO ||
		DialogoOperatoreObserver.OperazioneInCorso == Costanti.FINE_ATTREZZAGGIO;

	private DxMaskedInput<string?> BollaRef = null!;
	private DxMaskedInput<string?> OdpRef = null!;
	private DxComboBox<string, string> FasiRef = null!;
	private DotNetObjectReference<InfoBaseAttivita>? _dotNetRef;

	protected override Task OnInitializedAsync()
	{
		InfoBaseAttivitaViewModel.NotifyStateChanged += InfoBaseAttivitaViewModel_NotifyStateChanged;
		DialogoOperatoreObserver.OnIsDettaglioAttivitaOpenChanged += DialogoOperatoreObserver_OnIsDettaglioAttivitaOpenChanged;
		DialogoOperatoreObserver.OnOperatoreSelezionatoChanged += DialogoOperatoreObserver_OnOperatoreSelezionatoDeepLink;
		DialogoOperatoreObserver.OnOperazioneInCorsoChanged += async () => await InvokeAsync(StateHasChanged);

		return base.OnInitializedAsync();
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			await SetFocus(BollaRef);

			// Registra listener JS direttamente sugli <input> DOM
			// per intercettare Enter, Tab, e cambio focus (mouse/tablet)
			_dotNetRef = DotNetObjectReference.Create(this);
			await JS.InvokeVoidAsync("setupSearchInputs", _dotNetRef);
		}

		await base.OnAfterRenderAsync(firstRender);
	}

	[JSInvokable]
	public async Task OnBollaSearch(string value)
	{
		if (InfoBaseAttivitaViewModel.IsAttivitaSelezionata)
			return;

		Logger.LogInformation("[BOLLA] Ricerca da JS | Valore: '{Value}'", value);

		var sw = System.Diagnostics.Stopwatch.StartNew();
		InfoBaseAttivitaViewModel.CercaAttivitaDaBolla(value);
		Logger.LogInformation("[BOLLA] Ricerca completata in {Ms}ms | Fasi trovate: {Count}",
			sw.ElapsedMilliseconds, InfoBaseAttivitaViewModel.FasiPerAttivita?.Count() ?? 0);

		await InvokeAsync(StateHasChanged);
		await SetFocusToFasi();
	}

	[JSInvokable]
	public async Task OnOdpSearch(string value)
	{
		if (InfoBaseAttivitaViewModel.IsAttivitaSelezionata)
			return;

		var odp = value.PadLeft(8, '0');
		Logger.LogInformation("[ODP] Ricerca da JS | Valore: '{Value}' -> '{Odp}'", value, odp);

		InfoBaseAttivitaViewModel.Odp = odp;

		var sw = System.Diagnostics.Stopwatch.StartNew();
		InfoBaseAttivitaViewModel.CercaAttivitaDaOdp(odp);
		Logger.LogInformation("[ODP] Ricerca completata in {Ms}ms | Fasi trovate: {Count}",
			sw.ElapsedMilliseconds, InfoBaseAttivitaViewModel.FasiPerAttivita?.Count() ?? 0);

		await InvokeAsync(StateHasChanged);
		await SetFocusToFasi();
	}

	private async void InfoBaseAttivitaViewModel_NotifyStateChanged()
	{
		await InvokeAsync(StateHasChanged);
	}

	private async void DialogoOperatoreObserver_OnIsDettaglioAttivitaOpenChanged()
	{
		await Task.Delay(1);
		await SetFocus(BollaRef);
	}

	private async void DialogoOperatoreObserver_OnOperatoreSelezionatoDeepLink()
	{
		if (!DeepLinkParameters.HasDeepLink || string.IsNullOrEmpty(DeepLinkParameters.Odp))
			return;

		if (DialogoOperatoreObserver.OperatoreSelezionato == null)
			return;

		Logger.LogInformation("[DEEP LINK] Operatore selezionato, avvio ricerca ODP: {Odp}, Fase: {Fase}",
			DeepLinkParameters.Odp, DeepLinkParameters.Fase);

		// Apre il drawer impostando l'operazione "Inizio lavoro"
		DialogoOperatoreObserver.OperazioneInCorso = Costanti.INIZIO_LAVORO;

		// Aspetta che il drawer si apra e i campi vengano puliti dal ViewModel
		await Task.Delay(100);

		// Cerca l'ODP
		var odp = DeepLinkParameters.Odp;
		var fase = DeepLinkParameters.Fase;
		DeepLinkParameters.Consume();

		InfoBaseAttivitaViewModel.Odp = odp;
		InfoBaseAttivitaViewModel.CercaAttivitaDaOdp(odp);

		// Se specificata una fase, la seleziona
		if (!string.IsNullOrEmpty(fase) && InfoBaseAttivitaViewModel.FasiPerAttivita?.Any() == true)
		{
			var faseTarget = InfoBaseAttivitaViewModel.FasiPerAttivita
				.FirstOrDefault(f => f.StartsWith(fase));

			if (faseTarget != null)
			{
				InfoBaseAttivitaViewModel.FaseSelezionata = faseTarget;
				Logger.LogInformation("[DEEP LINK] Fase selezionata: {Fase}", faseTarget);
			}
		}

		await InvokeAsync(StateHasChanged);
	}

	private async Task SetFocus(IFocusableEditor element)
	{
		try
		{
			if (!DialogoOperatoreObserver.IsDettaglioAttivitaOpen)
				return;

			await Task.Delay(20);
			await element.FocusAsync();
		}
		catch
		{

		}
	}

	private async Task SetFocusToFasi()
	{
		await Task.Delay(10);

		if (FasiRef.Data.Count() != 0)
			await SetFocus(FasiRef);
	}

	private async void HandleFaseKeyPress(KeyboardEventArgs e)
	{
		List<string> listaFasi = InfoBaseAttivitaViewModel.FasiPerAttivita?.ToList() ?? new();

		int index = listaFasi.IndexOf(InfoBaseAttivitaViewModel.FaseSelezionata);

		switch (e.Key)
		{
			case "ArrowUp":
				if (listaFasi.Count <= 1)
					return;
				InfoBaseAttivitaViewModel.FaseSelezionata = index > 0 ? listaFasi[index - 1] : listaFasi[index];
				await SetFocus(FasiRef);
				break;

			case "ArrowDown":
				if (listaFasi.Count <= 1)
					return;
				InfoBaseAttivitaViewModel.FaseSelezionata = index < listaFasi.Count - 1 ? listaFasi[index + 1] : listaFasi[index];
				await SetFocus(FasiRef);
				break;

			case "Enter":
				await InfoBaseInserite.InvokeAsync();
				break;
		}
	}

	public async ValueTask DisposeAsync()
	{
		InfoBaseAttivitaViewModel.NotifyStateChanged -= InfoBaseAttivitaViewModel_NotifyStateChanged;
		DialogoOperatoreObserver.OnIsDettaglioAttivitaOpenChanged -= DialogoOperatoreObserver_OnIsDettaglioAttivitaOpenChanged;
		DialogoOperatoreObserver.OnOperatoreSelezionatoChanged -= DialogoOperatoreObserver_OnOperatoreSelezionatoDeepLink;
		_dotNetRef?.Dispose();
	}
}
